{
  "name": "markdown-viewer-desktop",
  "version": "2.6.0",
  "description": "Markdown Viewer & Editor — Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:dev": "electron . --dev",
    "package": "electron-forge package",
